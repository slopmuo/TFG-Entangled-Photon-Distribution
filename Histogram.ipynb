    "DATA_DIR = r\".\" \n",
    "def path(filename):\n",
    "    return os.path.join(DATA_DIR, filename)\n",
    "\n",
    "# ---- FILE NAMES ----\n",
    "FILE_HIST_DIRECT   = path(\"Bidirectional_histogram_source.txt\")\n",
    "FILE_HIST_DIST     = path(\"Bidirectional_histogram_final.txt\")\n",
    "FILE_COINC_DIRECT  = path(\"Counter_time_trace_coinc_s_source.txt\")\n",
    "FILE_COINC_DIST    = path(\"Counter_time_trace_coinc_s_final.txt\")\n",
    "FILE_SINGLE_DIRECT = path(\"Counter_time_trace_source.txt\")\n",
    "FILE_SINGLE_DIST   = path(\"Counter_time_trace_final.txt\")\n",
    "\n",
    "# Column names \n",
    "COINC_COL = 'Count rate (counts/s), channel Coincidences (4, 3)'\n",
    "CH3_COL   = 'Count rate (counts/s), channel 3'\n",
    "CH4_COL   = 'Count rate (counts/s), channel 4'\n",
    "\n",
    "# ---- 1. LOAD DATA ----\n",
    "df_hist_direct   = pd.read_csv(FILE_HIST_DIRECT,   sep='\\t')\n",
    "df_hist_dist     = pd.read_csv(FILE_HIST_DIST,     sep='\\t')\n",
    "df_coinc_direct  = pd.read_csv(FILE_COINC_DIRECT,  sep='\\t')\n",
    "df_coinc_dist    = pd.read_csv(FILE_COINC_DIST,    sep='\\t')\n",
    "df_single_direct = pd.read_csv(FILE_SINGLE_DIRECT, sep='\\t')\n",
    "df_single_dist   = pd.read_csv(FILE_SINGLE_DIST,   sep='\\t')\n",
    "\n",
    "# Convert time axes\n",
    "df_hist_direct['Time_ns']   = df_hist_direct['Time differences (ps)'] / 1000.0\n",
    "df_hist_dist['Time_ns']     = df_hist_dist['Time differences (ps)']   / 1000.0\n",
    "df_coinc_direct['Time_s']   = df_coinc_direct['Time (ps)'] / 1e12\n",
    "df_coinc_dist['Time_s']     = df_coinc_dist['Time (ps)']   / 1e12\n",
    "df_single_direct['Time_s']  = df_single_direct['Time (ps)'] / 1e12\n",
    "df_single_dist['Time_s']    = df_single_dist['Time (ps)']   / 1e12\n",
    "\n",
    "bin_direct_ps = abs(df_hist_direct['Time differences (ps)'].diff().dropna().iloc[0])\n",
    "bin_dist_ps   = abs(df_hist_dist['Time differences (ps)'].diff().dropna().iloc[0])\n",
    "\n",
    "# ---- 2. HISTOGRAM ANALYSIS ----\n",
    "def analyse_histogram(df, window_ns=0.5, bg_region_ns=2.0):\n",
    "    mask_bg   = (df['Time_ns'] < -bg_region_ns) | (df['Time_ns'] > bg_region_ns)\n",
    "    background = df[mask_bg]['Counts per bin'].mean()\n",
    "    max_counts = df['Counts per bin'].max()\n",
    "    peak_pos   = df.loc[df['Counts per bin'].idxmax(), 'Time_ns']\n",
    "    mask_peak  = (df['Time_ns'] >= -window_ns) & (df['Time_ns'] <= window_ns)\n",
    "    total_win  = df[mask_peak]['Counts per bin'].sum()\n",
    "    n_bins     = mask_peak.sum()\n",
    "    bg_win     = background * n_bins\n",
    "    true_coinc = total_win - bg_win\n",
    "    CAR = true_coinc / bg_win if bg_win > 0 else float('inf')\n",
    "    SNR = max_counts / background if background > 0 else float('inf')\n",
    "    return dict(background=background, max_counts=max_counts, peak_pos=peak_pos,\n",
    "                total_win=total_win, true_coinc=true_coinc, bg_win=bg_win,\n",
    "                CAR=CAR, SNR=SNR, n_bins=n_bins)\n",
    " \n",
    "stats_direct = analyse_histogram(df_hist_direct)\n",
    "stats_dist   = analyse_histogram(df_hist_dist)\n",
    " \n",
    "# ---- 3. RATE STATISTICS ----\n",
    "mc_dir = df_coinc_direct[COINC_COL].mean();  sc_dir = df_coinc_direct[COINC_COL].std()\n",
    "mc_dst = df_coinc_dist[COINC_COL].mean();    sc_dst = df_coinc_dist[COINC_COL].std()\n",
    "ratio  = mc_dst / mc_dir\n",
    " \n",
    "ms3_dir = df_single_direct[CH3_COL].mean(); ss3_dir = df_single_direct[CH3_COL].std()\n",
    "ms4_dir = df_single_direct[CH4_COL].mean(); ss4_dir = df_single_direct[CH4_COL].std()\n",
    "ms3_dst = df_single_dist[CH3_COL].mean();   ss3_dst = df_single_dist[CH3_COL].std()\n",
    "ms4_dst = df_single_dist[CH4_COL].mean();   ss4_dst = df_single_dist[CH4_COL].std()\n",
    " \n",
    "# ---- 4. PRINT RESULTS ----\n",
    "print(\"=\" * 62)\n",
    "print(\"   DISTRIBUTION COMPARISON — RESULTS SUMMARY\")\n",
    "print(\"=\" * 62)\n",
    "print(f\"\\n  Histogram bin sizes: direct={bin_direct_ps:.0f} ps | dist={bin_dist_ps:.0f} ps\")\n",
    " \n",
    "for label, s in [(\"DIRECT (no distribution)\", stats_direct),\n",
    "                 (\"DISTRIBUTION (~738 m)\",    stats_dist)]:\n",
    "    print(f\"\\n  [{label}]\")\n",
    "    print(f\"    Background:           {s['background']:.2f} counts/bin\")\n",
    "    print(f\"    Peak height:          {s['max_counts']:.0f} counts  (at {s['peak_pos']:.3f} ns)\")\n",
    "    print(f\"    SNR (peak/background):{s['SNR']:.1f}\")\n",
    "    print(f\"    CAR (±0.5 ns window): {s['CAR']:.1f}\")\n",
    "    print(f\"    True coincidences:    {s['true_coinc']:.0f}  (window ±0.5 ns)\")\n",
    " \n",
    "print(f\"\\n  Singles rates:\")\n",
    "print(f\"    Ch3 direct:  {ms3_dir:.0f} ± {ss3_dir:.0f} Hz  |  Ch3 dist: {ms3_dst:.0f} ± {ss3_dst:.0f} Hz  \"\n",
    "      f\"(ratio {ms3_dst/ms3_dir:.3f})\")\n",
    "print(f\"    Ch4 direct:  {ms4_dir:.0f} ± {ss4_dir:.0f} Hz  |  Ch4 dist: {ms4_dst:.0f} ± {ss4_dst:.0f} Hz  \"\n",
    "      f\"(ratio {ms4_dst/ms4_dir:.3f})\")\n",
    "print(f\"\\n  Coincidence rates:\")\n",
    "print(f\"    Direct:       {mc_dir:.1f} ± {sc_dir:.1f} counts/s\")\n",
    "print(f\"    Distribution: {mc_dst:.1f} ± {sc_dst:.1f} counts/s\")\n",
    "print(f\"    Ratio:        {ratio:.3f}  →  {1/ratio:.1f}× reduction\")\n",
    "print(\"=\" * 62)\n",
    " \n",
    "# ---- 5. PLOTS ----\n",
    "colors = {'direct': 'indigo', 'dist': 'darkorange'}\n",
    "fig, axes = plt.subplots(4, 2, figsize=(16, 20))\n",
    "fig.suptitle(\n",
    "    'Entangled Photon Distribution — Direct source vs Inter-laboratory (~738 m)\\n'\n",
    "    'Attenuator: 9 dB on each detector',\n",
    "    fontsize=13, fontweight='bold', y=1.025\n",
    ")\n",
    "# ---- 5a. Histograms — full view ----\n",
    "ax = axes[0, 0]\n",
    "ax.plot(df_hist_direct['Time_ns'], df_hist_direct['Counts per bin'],\n",
    "        color=colors['direct'], drawstyle='steps-mid', lw=1.2,\n",
    "        label=f'Direct  (bin={bin_direct_ps:.0f} ps)')\n",
    "ax.plot(df_hist_dist['Time_ns'], df_hist_dist['Counts per bin'],\n",
    "        color=colors['dist'], drawstyle='steps-mid', lw=1.2,\n",
    "        label=f'Distribution  (bin={bin_dist_ps:.0f} ps)')\n",
    "ax.axhline(stats_direct['background'], color=colors['direct'], ls='--', alpha=0.6,\n",
    "           label=f\"BG direct: {stats_direct['background']:.1f}\")\n",
    "ax.axhline(stats_dist['background'],   color=colors['dist'],   ls='--', alpha=0.6,\n",
    "           label=f\"BG dist: {stats_dist['background']:.1f}\")\n",
    "ax.set_xlim(-5, 5)\n",
    "ax.set_xlabel(r'Time difference $\\Delta t$ (ns)', fontsize=11)\n",
    "ax.set_ylabel('Counts per bin', fontsize=11)\n",
    "ax.set_title('Coincidence histogram (±5 ns)', fontsize=11, fontweight='bold')\n",
    "ax.legend(fontsize=9);  ax.grid(True, alpha=0.3, linestyle='--')\n",
    " \n",
    "# ---- 5b. Histograms — peak zoom ----\n",
    "ax = axes[0, 1]\n",
    "ax.plot(df_hist_direct['Time_ns'], df_hist_direct['Counts per bin'],\n",
    "        color=colors['direct'], drawstyle='steps-mid', lw=1.5,\n",
    "        label=f'Direct  (CAR = {stats_direct[\"CAR\"]:.1f}, SNR = {stats_direct[\"SNR\"]:.1f})')\n",
    "ax.plot(df_hist_dist['Time_ns'], df_hist_dist['Counts per bin'],\n",
    "        color=colors['dist'], drawstyle='steps-mid', lw=1.5,\n",
    "        label=f'Distribution  (CAR = {stats_dist[\"CAR\"]:.1f}, SNR = {stats_dist[\"SNR\"]:.1f})')\n",
    "ax.axhline(stats_direct['background'], color=colors['direct'], ls='--', alpha=0.5)\n",
    "ax.axhline(stats_dist['background'],   color=colors['dist'],   ls='--', alpha=0.5)\n",
    "ax.axvspan(-0.5, 0.5, alpha=0.08, color='green', label='±0.5 ns integration window')\n",
    "ax.set_xlim(-2, 2)\n",
    "ax.set_xlabel(r'Time difference $\\Delta t$ (ns)', fontsize=11)\n",
    "ax.set_ylabel('Counts per bin', fontsize=11)\n",
    "ax.set_title('Coincidence histogram — peak zoom (±2 ns)', fontsize=11, fontweight='bold')\n",
    "ax.legend(fontsize=9);  ax.grid(True, alpha=0.3, linestyle='--')\n",
    " \n",
    "# ---- 5c. Singles Ch3 ----\n",
    "ax = axes[2, 0]\n",
    "ax.plot(df_single_direct['Time_s'], df_single_direct[CH3_COL],\n",
    "        color=colors['direct'], lw=1.0, alpha=0.8,\n",
    "        label=f'Direct  ({ms3_dir:.0f} ± {ss3_dir:.0f} Hz)')\n",
    "ax.plot(df_single_dist['Time_s'], df_single_dist[CH3_COL],\n",
    "        color=colors['dist'], lw=1.2, alpha=0.9,\n",
    "        label=f'Distribution  ({ms3_dst:.0f} ± {ss3_dst:.0f} Hz)')\n",
    "ax.axhline(ms3_dir, color=colors['direct'], ls='--', lw=1.2, alpha=0.7)\n",
    "ax.axhline(ms3_dst, color=colors['dist'],   ls='--', lw=1.2, alpha=0.7)\n",
    "ax.set_xlabel('Time (s)', fontsize=11);  ax.set_ylabel('Count rate (Hz)', fontsize=11)\n",
    "ax.set_title(f'Singles rate — Channel 3 (SPAD 1)\\nRatio: {ms3_dst/ms3_dir:.3f}  ({ms3_dir/ms3_dst:.1f}× reduction)',\n",
    "             fontsize=11, fontweight='bold')\n",
    "ax.legend(fontsize=10);  ax.grid(True, alpha=0.3, linestyle='--')\n",
    " \n",
    "# ---- 5d. Singles Ch4 ----\n",
    "ax = axes[2, 1]\n",
    "ax.plot(df_single_direct['Time_s'], df_single_direct[CH4_COL],\n",
    "        color=colors['direct'], lw=1.0, alpha=0.8,\n",
    "        label=f'Direct  ({ms4_dir:.0f} ± {ss4_dir:.0f} Hz)')\n",
    "ax.plot(df_single_dist['Time_s'], df_single_dist[CH4_COL],\n",
    "        color=colors['dist'], lw=1.2, alpha=0.9,\n",
    "        label=f'Distribution  ({ms4_dst:.0f} ± {ss4_dst:.0f} Hz)')\n",
    "ax.axhline(ms4_dir, color=colors['direct'], ls='--', lw=1.2, alpha=0.7)\n",
    "ax.axhline(ms4_dst, color=colors['dist'],   ls='--', lw=1.2, alpha=0.7)\n",
    "ax.set_xlabel('Time (s)', fontsize=11);  ax.set_ylabel('Count rate (Hz)', fontsize=11)\n",
    "ax.set_title(f'Singles rate — Channel 4 (SPAD 2)\\nRatio: {ms4_dst/ms4_dir:.3f}  ({ms4_dir/ms4_dst:.1f}× reduction)',\n",
    "             fontsize=11, fontweight='bold')\n",
    "ax.legend(fontsize=10);  ax.grid(True, alpha=0.3, linestyle='--')\n",
    " \n",
    "# ---- 5e. Coincidence rate vs time ----\n",
    "ax = axes[3, 0]\n",
    "ax.plot(df_coinc_direct['Time_s'], df_coinc_direct[COINC_COL],\n",
    "        color=colors['direct'], lw=1.2, alpha=0.85,\n",
    "        label=f'Direct  ({mc_dir:.1f} ± {sc_dir:.1f} cts/s)')\n",
    "ax.plot(df_coinc_dist['Time_s'], df_coinc_dist[COINC_COL],\n",
    "        color=colors['dist'], lw=1.2, alpha=0.85,\n",
    "        label=f'Distribution  ({mc_dst:.1f} ± {sc_dst:.1f} cts/s)')\n",
    "ax.axhline(mc_dir, color=colors['direct'], ls='--', lw=1.2, alpha=0.7)\n",
    "ax.axhline(mc_dst, color=colors['dist'],   ls='--', lw=1.2, alpha=0.7)\n",
    "ax.set_xlabel('Time (s)', fontsize=11);  ax.set_ylabel('Coincidence rate (counts/s)', fontsize=11)\n",
    "ax.set_title('Coincidence rate over time', fontsize=11, fontweight='bold')\n",
    "ax.legend(fontsize=10);  ax.grid(True, alpha=0.3, linestyle='--')\n",
    " \n",
    "# ---- 5f. Summary — normalised ratios ----\n",
    "ax = axes[3, 1]\n",
    "categories  = ['Ch3 singles', 'Ch4 singles', 'Coincidences', 'CAR']\n",
    "direct_vals = [ms3_dir,       ms4_dir,       mc_dir,          stats_direct['CAR']]\n",
    "dist_vals   = [ms3_dst,       ms4_dst,       mc_dst,          stats_dist['CAR']]\n",
    "ratios      = [d2/d1 for d1, d2 in zip(direct_vals, dist_vals)]\n",
    " \n",
    "x = np.arange(len(categories));  w = 0.5\n",
    "bar_colors  = [colors['dist'] if r < 1 else '#4CAF50' for r in ratios]\n",
    "bars = ax.bar(x, ratios, w, color=bar_colors, alpha=0.85, edgecolor='white', lw=1.2)\n",
    "ax.axhline(1.0, color='black', ls='--', lw=1.2, alpha=0.6, label='Direct reference')\n",
    " \n",
    "# Annotate value and percentage change above/below each bar\n",
    "for i, (r, d1, d2) in enumerate(zip(ratios, direct_vals, dist_vals)):\n",
    "    unit = 'Hz' if i < 2 else ('cts/s' if i == 2 else '')\n",
    "    label = f'{r:.2f}×\\n({d1:.0f}→{d2:.0f} {unit})'\n",
    "    y_txt = r + 0.03 if r >= 0.15 else 0.03\n",
    "    ax.text(i, y_txt, label, ha='center', va='bottom', fontsize=8.5,\n",
    "            fontweight='bold', color='black')\n",
    " \n",
    "ax.set_xticks(x);  ax.set_xticklabels(categories, fontsize=10)\n",
    "ax.set_ylim(0, 1.25)\n",
    "ax.set_ylabel('Ratio  (distribution / direct)', fontsize=11)\n",
    "ax.set_title('Performance summary — normalised ratios\\n'\n",
    "             '(1.0 = direct source level; lower = more loss)',\n",
    "             fontsize=11, fontweight='bold')\n",
    "ax.legend(fontsize=10);  ax.grid(axis='y', alpha=0.3)\n",
    " \n",
    " \n",
    "# ---- 5g. Normalised histograms — full view ----\n",
    "norm_direct = df_hist_direct[\"Counts per bin\"] / bin_direct_ps\n",
    "norm_dist   = df_hist_dist[\"Counts per bin\"]   / bin_dist_ps\n",
    "bg_norm_direct = stats_direct[\"background\"] / bin_direct_ps\n",
    "bg_norm_dist   = stats_dist[\"background\"]   / bin_dist_ps\n",
    " \n",
    "ax = axes[1, 0]\n",
    "ax.plot(df_hist_direct[\"Time_ns\"], norm_direct, color=colors[\"direct\"],\n",
    "        drawstyle=\"steps-mid\", lw=1.2, label=f\"Direct  (bin={bin_direct_ps:.0f} ps)\")\n",
    "ax.plot(df_hist_dist[\"Time_ns\"],   norm_dist,   color=colors[\"dist\"],\n",
    "        drawstyle=\"steps-mid\", lw=1.2, label=f\"Distribution  (bin={bin_dist_ps:.0f} ps)\")\n",
    "ax.axhline(bg_norm_direct, color=colors[\"direct\"], ls=\"--\", alpha=0.6,\n",
    "           label=f\"BG direct: {bg_norm_direct:.3f} cts/ps\")\n",
    "ax.axhline(bg_norm_dist,   color=colors[\"dist\"],   ls=\"--\", alpha=0.6,\n",
    "           label=f\"BG dist: {bg_norm_dist:.3f} cts/ps\")\n",
    "ax.set_xlim(-5, 5)\n",
    "ax.set_xlabel(\"Time difference dt (ns)\", fontsize=11)\n",
    "ax.set_ylabel(\"Counts per ps\", fontsize=11)\n",
    "ax.set_title(\"Coincidence histogram — bin-normalised (±5 ns) — Both curves on the same scale\",\n",
    "             fontsize=11, fontweight=\"bold\")\n",
    "ax.legend(fontsize=9);  ax.grid(True, alpha=0.3, linestyle=\"--\")\n",
    " \n",
    "# ---- 5h. Normalised histograms — peak zoom ----\n",
    "ax = axes[1, 1]\n",
    "ax.plot(df_hist_direct[\"Time_ns\"], norm_direct, color=colors[\"direct\"],\n",
    "        drawstyle=\"steps-mid\", lw=1.5, label=f\"Direct  (peak {norm_direct.max():.2f} cts/ps)\")\n",
    "ax.plot(df_hist_dist[\"Time_ns\"],   norm_dist,   color=colors[\"dist\"],\n",
    "        drawstyle=\"steps-mid\", lw=1.5, label=f\"Distribution  (peak {norm_dist.max():.2f} cts/ps)\")\n",
    "ax.axhline(bg_norm_direct, color=colors[\"direct\"], ls=\"--\", alpha=0.5)\n",
    "ax.axhline(bg_norm_dist,   color=colors[\"dist\"],   ls=\"--\", alpha=0.5)\n",
    "ax.axvspan(-0.5, 0.5, alpha=0.08, color=\"green\", label=\"±0.5 ns integration window\")\n",
    "ax.set_xlim(-2, 2)\n",
    "ax.set_xlabel(\"Time difference dt (ns)\", fontsize=11)\n",
    "ax.set_ylabel(\"Counts per ps\", fontsize=11)\n",
    "peak_ratio = norm_dist.max() / norm_direct.max()\n",
    "ax.set_title(f\"Bin-normalised — peak zoom (±2 ns)  |  Peak reduction: {peak_ratio:.2f}x  ({norm_direct.max():.2f} to {norm_dist.max():.2f} cts/ps)\",\n",
    "             fontsize=11, fontweight=\"bold\")\n",
    "ax.legend(fontsize=9);  ax.grid(True, alpha=0.3, linestyle=\"--\")\n",
    " \n",
    "plt.tight_layout()\n",
    "plt.savefig('distribution_comparison.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  }
 ],
