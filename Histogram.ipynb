   "source": [
    "# 1. Load the rate data\n",
    "file_rate = \"Entangled_photon_source_rate_10_dB.txt\"\n",
    "df_rate = pd.read_csv(file_rate, sep='\\t')\n",
    "\n",
    "# 2. Load the exported correlation histogram\n",
    "file_hist = \"Entangled_photon_source_rate_10_dB_correlation_histogram.txt\"\n",
    "df_hist = pd.read_csv(file_hist, sep='\\t')\n",
    "\n",
    "# --- PART A: DETECTOR STATISTICS ---\n",
    "ch3_col = 'Count rate (counts/s), channel 3'\n",
    "ch4_col = 'Count rate (counts/s), channel 4'\n",
    "\n",
    "print(\"=== SOURCE STATISTICS (10 dB) ===\")\n",
    "for label, col in [(\"Channel 3\", ch3_col), (\"Channel 4\", ch4_col)]:\n",
    "    mean_val = df_rate[col].mean()\n",
    "    std_val = df_rate[col].std()\n",
    "    var_val = df_rate[col].var()\n",
    "    print(f\"{label}: Average = {round(mean_val)} Hz | Std Dev = {round(std_val)} | Variance = {round(var_val)}\")\n",
    "\n",
    "# --- PART B: COINCIDENCE HISTOGRAM ---\n",
    "# Convert picoseconds to nanoseconds for readability\n",
    "df_hist['Time_ns'] = df_hist['Time differences (ps)'] / 1000.0\n",
    "\n",
    "plt.figure(figsize=(12, 6))\n",
    "plt.plot(df_hist['Time_ns'], df_hist['Counts per bin'], color='indigo', drawstyle='steps-mid', label='Coincidences')\n",
    "\n",
    "# Identify the maximum peak\n",
    "max_counts = df_hist['Counts per bin'].max()\n",
    "peak_pos_ns = df_hist.loc[df_hist['Counts per bin'].idxmax(), 'Time_ns']\n",
    "\n",
    "# Calculate background (accidental coincidences) by averaging zones far from the peak\n",
    "# We take data outside the +/- 2ns window around the peak\n",
    "baseline = df_hist[(df_hist['Time_ns'] < peak_pos_ns - 2) | (df_hist['Time_ns'] > peak_pos_ns + 2)]['Counts per bin'].mean()\n",
    "snr = max_counts / baseline\n",
    "\n",
    "# Plot formatting\n",
    "plt.axvline(x=peak_pos_ns, color='crimson', linestyle='--', alpha=0.6, label=f'Peak at {peak_pos_ns:.2f} ns')\n",
    "plt.title('Task 2: Entangled Photon Correlation Histogram (EPPS Source)', fontsize=14)\n",
    "plt.xlabel(r'Time Difference $\\Delta t = t_4 - t_3$ (ns)', fontsize=12)\n",
    "plt.ylabel('Counts per bin', fontsize=12)\n",
    "plt.legend()\n",
    "plt.grid(True, alpha=0.3)\n",
    "\n",
    "print(f\"\\n=== PEAK ANALYSIS ===\")\n",
    "print(f\"Peak Position: {peak_pos_ns:.2f} ns\")\n",
    "print(f\"Peak Height: {max_counts} counts\")\n",
    "print(f\"Average Background (moderate level of ‘noise’ or false random matches): {baseline:.2f}\")\n",
    "print(f\"Signal-to-Noise Ratio (SNR): {snr:.2f} (For every false positive, there are {int(snr)} true positives)\")\n",
    "\n",
    "plt.show()"
   ]
