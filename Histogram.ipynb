   "source": [
    "### TASK 1: Dark Counts Histogram (Channels 3 & 4) ###\n",
    "\n",
    "file1 = \"Dark_counts_events_2026-03-27_113653.ttbin\"\n",
    "file2 = \"Dark_counts_events_2026-03-27_113653.1.ttbin\"\n",
    "\n",
    "# Create the virtual device with the first file\n",
    "tagger_virtual = createTimeTaggerVirtual(file1)\n",
    "# Add the second file to the processing queue\n",
    "tagger_virtual.appendFile(file2)\n",
    " \n",
    "# VIRTUAL INSTRUMENTS SETUP\n",
    "# Binwidth is set to 0.1s (1e11 ps) to calculate Hz\n",
    "active_channels = [3, 4, 5, 6]\n",
    "rate_counter = Counter(tagger_virtual, channels=active_channels, binwidth=100000000000, n_values=6000)\n",
    "\n",
    "# Correlation histogram between Ch 3 and 4 (standard for entanglement comparison)\n",
    "histogram = Correlation(tagger_virtual, channel_1=3, channel_2=4, binwidth=100, n_bins=2000)\n",
    "\n",
    "# DATA PROCESSING\n",
    "tagger_virtual.run() \n",
    "# Wait for the virtual engine to finish reading the binary data\n",
    "time.sleep(5) \n",
    "\n",
    "# DATA EXTRACTION AND CALCULATION\n",
    "raw_data = rate_counter.getData() # convert it into a Matrix where the rows are the channels and the columns are each bintime(0.1s)\n",
    "\n",
    "print(\"\\n\" + \"=\"*45)\n",
    "print(\" TASK 1 RESULTS: DARK COUNTS CHARACTERIZATION\")\n",
    "print(\"=\"*45)\n",
    "\n",
    "for i, ch in enumerate(active_channels): ## convert into [(0,3),(1,4),(2,5),(3,6)]\n",
    "    total_counts = np.sum(raw_data[i])\n",
    "    active_slots = np.count_nonzero(raw_data[i]) # in 0.1s\n",
    "    \n",
    "    # Calculate average Rate in Hz (Total counts / Total active time)\n",
    "    if active_slots > 0:\n",
    "        average_hz = (total_counts / active_slots * 10)\n",
    "    else:\n",
    "        average_hz = 0.0\n",
    "        \n",
    "    print(f\"Detector Channel {ch}: {average_hz:>10.2f} Hz\")\n",
    "print(\"=\"*45)\n",
    "\n",
    "# HISTOGRAM EXTRACTION\n",
    "hist_counts = histogram.getData()\n",
    "time_axis_ns = histogram.getIndex() / 1000.0 # Convert ps to ns. getIndex extracts the list of time from the histogram in ps (axis y)\n",
    "\n",
    "# Release hardware memory\n",
    "freeTimeTagger(tagger_virtual)\n",
    "\n",
    "# PLOTTING\n",
    "plt.figure(figsize=(10, 6))\n",
    "plt.plot(time_axis_ns, hist_counts, color='dimgray', drawstyle='steps-mid', label='Dark Count Coincidences (3-4)')\n",
    "plt.axhline(y=np.mean(hist_counts), color='crimson', linestyle='--', alpha=0.6, label='Average background level')\n",
    "\n",
    "plt.title('Dark Counts Histogram (Channels 3 & 4)', fontsize=14, fontweight='bold')\n",
    "plt.xlabel('Time Difference (ns)', fontsize=12)\n",
    "plt.ylabel('Counts per bin (*100 ps*)', fontsize=12)\n",
    "plt.grid(True, alpha=0.3, linestyle='--')\n",
    "plt.legend(loc='upper right')\n",
    "\n",
    "# Set Y axis limits to ensure visibility even if counts are zero\n",
    "y_limit = max(hist_counts) + 5 if max(hist_counts) > 0 else 10\n",
    "plt.ylim(-0.5, y_limit)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
