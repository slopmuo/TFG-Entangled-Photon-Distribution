   "source": [
    "# 1. Read the text file (tab-separated)\n",
    "file = \"Dark_counts_rate.txt\"\n",
    "df = pd.read_csv(file, sep='\\t')\n",
    "\n",
    "# Picoseconds to seconds\n",
    "df['Time (s)'] = df['Time (ps)'] / 1e12\n",
    "\n",
    "# 2. Calculate detections in the first 60 seconds\n",
    "df_60s = df[df['Time (s)'] <= 60]\n",
    "\n",
    "# Find columns that contain the raw counts per bin\n",
    "count_columns = [col for col in df.columns if 'Counts per bin' in col]\n",
    "\n",
    "print(\"--- DETECTIONS IN THE FIRST 60 SECONDS ---\")\n",
    "for col in count_columns:\n",
    "    # Extract the channel number from the column name\n",
    "    channel = col.split()[-1]\n",
    "    \n",
    "    # Calculate total counts and average rate (counts/second)\n",
    "    total_counts = int(df_60s[col].sum())\n",
    "    average_rate = total_counts / 60.0\n",
    "    \n",
    "    print(f\"Channel {channel}: {total_counts} counts | Average rate: {average_rate:.0f} counts/s\")\n",
    "\n",
    "# 3. Plot the Histogram of the Dark Count Rates\n",
    "# Find columns that contain the count rates\n",
    "rate_columns = [col for col in df.columns if 'Count rate' in col]\n",
    "bg_color = 'white'\n",
    "plt.figure(figsize=(10, 6), facecolor = bg_color)\n",
    "colors = ['blue', 'orange', 'green', 'red']\n",
    "\n",
    "# Plot a histogram for each channel\n",
    "for i, col in enumerate(rate_columns):\n",
    "    channel = col.split()[-1]\n",
    "    plt.hist(df[col], bins=150, alpha=0.6, label=f'Channel {channel}', color=colors[i])\n",
    "\n",
    "# Configure chart details\n",
    "plt.title('Dark Count Rates Histogram per Detector', fontsize=14, fontweight='bold')\n",
    "plt.xlabel('Count Rate (counts/s)', fontsize=12)\n",
    "plt.ylabel('Frequency', fontsize=12)\n",
    "plt.legend()\n",
    "plt.grid(axis='y', alpha=0.5)\n",
    "plt.tight_layout()\n",
    "# Cambiar el color de los números y las marcas de los ejes a blanco\n",
    "#plt.tick_params(colors='white')\n",
    "# Display the plot\n",
    "plt.savefig('dark_counts_histogram.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
