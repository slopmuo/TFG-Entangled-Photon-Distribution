   "source": [
    "### TASK 2: Entangled Photon Correlation Histogram (EPPS Source) ###\n",
    "# 1. Load the rate data\n",
    "file_rate = \"Entangled_photon_source_rate_10_dB.txt\"\n",
    "df_rate = pd.read_csv(file_rate, sep='\\t')\n",
    "\n",
    "# 2. Load the exported correlation histogram\n",
    "file_hist = \"Entangled_photon_source_rate_10_dB_correlation_histogram.txt\"\n",
    "df_hist = pd.read_csv(file_hist, sep='\\t')\n",
    "\n",
    "# --- A. DETECTOR STATISTICS ---\n",
    "ch3_col = 'Count rate (counts/s), channel 3'\n",
    "ch4_col = 'Count rate (counts/s), channel 4'\n",
    "\n",
    "print(\"=== SOURCE STATISTICS (10 dB) ===\")\n",
    "for label, col in [(\"Channel 3\", ch3_col), (\"Channel 4\", ch4_col)]:\n",
    "    mean_val = df_rate[col].mean()\n",
    "    std_val = df_rate[col].std()\n",
    "    var_val = df_rate[col].var()\n",
    "    print(f\"{label}: Average = {round(mean_val)} Hz | Std Dev = {round(std_val)} Hz | Variance = {round(var_val)} Hz²\")\n",
    "\n",
    "# --- B. COINCIDENCE HISTOGRAM & DELAY CORRECTION ---\n",
    "# Convert picoseconds to nanoseconds for readability\n",
    "df_hist['Time_ns'] = df_hist['Time differences (ps)'] / 1000.0\n",
    "\n",
    "# 1. Identify the natural peak position (Physical delay due to fibers/spectrum)\n",
    "max_counts = df_hist['Counts per bin'].max()\n",
    "original_peak_pos_ns = df_hist.loc[df_hist['Counts per bin'].idxmax(), 'Time_ns']\n",
    "\n",
    "# 2. APPLY THE OFFSET: Shift the time axis so the peak is exactly at 0.0 ns\n",
    "df_hist['Time_ns_shifted'] = df_hist['Time_ns'] - original_peak_pos_ns\n",
    "\n",
    "# 3. Calculate background (accidental coincidences) by averaging zones far from the peak\n",
    "baseline = df_hist[(df_hist['Time_ns_shifted'] < -2) | (df_hist['Time_ns_shifted'] > 2)]['Counts per bin'].mean()\n",
    "\n",
    "# 4. CALCULATING THE AREA OF THE PEAK (Real entanglement pairs)\n",
    "mask_peak = (df_hist['Time_ns_shifted'] >= -0.5) & (df_hist['Time_ns_shifted'] <= 0.5)\n",
    "total_counts_window = df_hist[mask_peak]['Counts per bin'].sum()\n",
    "num_bins_in_window = mask_peak.sum()\n",
    "true_coincidences = total_counts_window - (baseline * num_bins_in_window)\n",
    "\n",
    "# 5. SIGNAL-TO-NOISE RATIO (SNR)\n",
    "snr = max_counts / baseline if baseline > 0 else 0\n",
    "\n",
    "# --- C. PLOTTING (BEFORE AND AFTER) ---\n",
    "# (1 row, 2 columns)\n",
    "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(15, 6),facecolor=bg_color)\n",
    "bg_color = 'white'\n",
    "# ---- PLOT 1: ORIGINAL (Left) ----\n",
    "ax1.plot(df_hist['Time_ns'], df_hist['Counts per bin'], color='indigo', drawstyle='steps-mid', label='Coincidences')\n",
    "ax1.axvline(x=original_peak_pos_ns, color='crimson', linestyle='--', alpha=0.6, label=f'Peak at {original_peak_pos_ns:.2f} ns')\n",
    "ax1.axhline(y=baseline, color='gray', linestyle='--', alpha=0.7, label=f'Background: {baseline:.1f}')\n",
    "\n",
    "ax1.set_title('Original Histogram (Physical Delay)', fontsize=14, fontweight='bold')\n",
    "ax1.set_xlabel(r'Time Difference $\\Delta t = t_4 - t_3$ (ns)', fontsize=12)\n",
    "ax1.set_ylabel('Counts per bin', fontsize=12)\n",
    "ax1.legend(loc='upper left')\n",
    "ax1.grid(True, alpha=0.3, linestyle='--')\n",
    "\n",
    "# ---- PLOT 2: SHIFTED (Right) ----\n",
    "ax2.plot(df_hist['Time_ns_shifted'], df_hist['Counts per bin'], color='teal', drawstyle='steps-mid', label='Aligned Coincidences')\n",
    "ax2.axvline(x=0.0, color='crimson', linestyle='--', alpha=0.6, label='Virtual Zero (Aligned)')\n",
    "ax2.axhline(y=baseline, color='gray', linestyle='--', alpha=0.7, label=f'Background: {baseline:.1f}')\n",
    "\n",
    "ax2.set_title('Corrected Histogram (Shifted to 0 ns)', fontsize=14, fontweight='bold')\n",
    "ax2.set_xlabel(r'Time Difference $\\Delta t = t_4 - t_3$ (ns)', fontsize=12)\n",
    "ax2.set_ylabel('Counts per bin', fontsize=12, color = 'white')\n",
    "ax2.set_xlim(-5, 5)\n",
    "ax2.legend(loc='upper right')\n",
    "ax2.grid(True, alpha=0.3, linestyle='--')\n",
    "\n",
    "plt.tight_layout() # Adjusts the margins automatically so they don't overlap\n",
    "\n",
    "# Cambiar el color de los números y las marcas de los ejes a blanco\n",
    "#ax1.tick_params(colors='white')\n",
    "#ax2.tick_params(colors='white')\n",
    "\n",
    "print(f\"\\n=== PEAK ANALYSIS ===\")\n",
    "print(f\"Original Physical Delay Detected: {original_peak_pos_ns:.2f} ns\")\n",
    "print(f\"Corrected Peak Position: 0.00 ns\")\n",
    "print(f\"Peak Maximum Height: {max_counts} counts\")\n",
    "print(f\"Average Background (noise/false matches): {baseline:.2f} counts/bin (bin = 10ps)\")\n",
    "print(f\"Signal-to-Noise Ratio (SNR): {snr:.2f} (For every false positive, there are ~{int(snr)} true positives)\")\n",
    "print(f\"--------------------------------------------------\")\n",
    "print(f\"TOTAL DETECTIONS (Window +/- 0.5 ns): {int(total_counts_window)} coincidences\")\n",
    "print(f\"TRUE ENTANGLED PAIRS (Total - noise(background)): {int(true_coincidences)} pairs\")\n",
    "\n",
    "plt.savefig('source_histogram.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
