    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "from TimeTagger import createTimeTaggerVirtual, freeTimeTagger, Correlation, Counter\n" # Requires a valid Swabian Instruments Time Tagger license to run this cell,
    "import time\n",
    "import os"
   ]
